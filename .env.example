# --- DeepSeek ---
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
# deepseek-v4-* default to thinking mode; false = faster/cheaper, enables forced tool_choice.
DEEPSEEK_THINKING=false

# --- Signal transport (signal-cli-rest-api) ---
# Base HTTP URL of the signal-cli-rest-api container (json-rpc mode).
SIGNAL_API_URL=http://signal-cli-rest-api:8080
# The bot's own registered phone number, E.164 format.
BOT_NUMBER=+61400000000


# --- Lockdown / behaviour ---
# Comma-separated internal group ids the bot will respond in (from `signal-chatbot groups`).
ALLOWED_GROUP_IDS=group.EXAMPLEBASE64GROUPID=
# Optional comma-separated sender numbers allowlist. Empty = any member of an allowed group.
ALLOWED_SENDERS=
# Mention that triggers the bot (case-insensitive).
TRIGGER_ALIAS=@bot
# Chance (0..1) the bot chimes in unprompted on a message that didn't summon it. 0 disables.
UNPROMPTED_REPLY_CHANCE=0.05
# Path to the system prompt file.
SYSTEM_PROMPT_PATH=prompts/identity.md
# Max number of recent messages kept per group as LLM context.
HISTORY_WINDOW_MAX=40
# SQLite database path for the rolling history.
DATABASE_PATH=data/history.sqlite
# Max tool-calling round trips per reply.
MAX_TOOL_ITERATIONS=25
# Command-activity events (who ran what command, when) kept per group as context.
COMMAND_LOG_WINDOW=40
# Character cap on the @reset farewell sentence.
RESET_FAREWELL_MAX_CHARS=200
# Display name the bot is reset to by @lobotomy.
DEFAULT_DISPLAY_NAME=bot
# IANA timezone for human-facing timestamps (summon prompt, @lists). Australia/Sydney
# auto-switches AEST (UTC+10) and AEDT (UTC+11) with daylight saving.
DISPLAY_TIMEZONE=Australia/Sydney


# --- Wikipedia lookup ---
# Wikipedia language edition (e.g. en, de, fr) used for search and articles.
WIKIPEDIA_LANGUAGE=en
# How long Wikipedia results are cached, in seconds (21600 = 6h).
WIKIPEDIA_CACHE_TTL_SECONDS=21600
# Number of search hits returned by wikipedia_search.
WIKIPEDIA_SEARCH_LIMIT=5
# Character cap on a single article section before truncation.
WIKIPEDIA_MAX_SECTION_CHARS=2000
# User-Agent sent to the Wikimedia API. Wikimedia requires a descriptive
# value with contact info; generic agents may be rate-limited or blocked.
WIKIPEDIA_USER_AGENT=signal-chatbot/0.1 (https://github.com/you/signal-chatbot; you@example.com)
